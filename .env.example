# webhooks.email -- environment variables. Copy to .env (which is gitignored).
# NEVER commit real keys. Rotate anything that has ever been committed.

# --- backend/main.py (FastAPI proxy, port 8000) ---
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# Comma-separated CORS allowlist (defaults to webhooks.email + localhost)
BACKEND_ALLOWED_ORIGINS=https://webhooks.email,http://127.0.0.1:8080
# Anonymous free-tier daily limit per IP (zero-key first run)
FREE_DAILY_LIMIT=3

# --- ingress/webhook_handler.py (port 8001) ---
# Uses OPENROUTER_API_KEY (above). Comma-separated keys allowed to call ingress;
# if empty the ingress is OPEN -- set this in production.
INGRESS_API_KEYS=
DESKTOP_FORWARD_URL=http://127.0.0.1:3000
DESKTOP_FORWARD_KEY=REPLACE_ME

# --- receiver.js (desktop bridge, port 3000) ---
# If unset, receiver.js generates a random key at startup and prints it.
RECEIVER_API_KEY=

# --- worker/ (Cloudflare) -- set these as SECRETS, not in this file ---
#   wrangler secret put PROXY_SECRET        # gates /api/generate on the worker
#   wrangler secret put OPENROUTER_API_KEY  # the worker's OpenRouter key
